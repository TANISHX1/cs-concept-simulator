  "language": "c",
  "sourceCode": "int binarySearch(int array[], int length, int target) {\n  int low = 0;\n  int high = length - 1;\n\n  while (low <= high) {\n    int middle = low + (high - low) / 2;\n\n    if (array[middle] == target) {\n      return middle;\n    }\n\n    if (target < array[middle]) {\n      high = middle - 1;\n    } else {\n      low = middle + 1;\n    }\n  }\n\n  return -1;\n}",
